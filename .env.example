# Copy this file to .env and fill in the values you want to test with.
# Used by: npx @github/local-action run . src/index.js .env
#
# Input names map to INPUT_<NAME> in uppercase (hyphens preserved).

# Required: comma-separated directory paths to scan
INPUT_PATHS=__tests__/fixtures

# Optional: comma-separated file extensions to look for (default shown)
INPUT_FILE-EXTENSIONS=jpg,jpeg,png,gif,webp,avif,tiff,svg

# Optional: file size constraints in bytes (leave blank to skip)
INPUT_MIN-SIZE=
INPUT_MAX-SIZE=

# Optional: image dimension constraints in pixels (leave blank to skip)
INPUT_MIN-WIDTH=
INPUT_MAX-WIDTH=1980
INPUT_MIN-HEIGHT=
INPUT_MAX-HEIGHT=

# Optional: set to 'false' to report violations as warnings instead of failing (default: true)
INPUT_FAIL-ON-ERROR=true

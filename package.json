{
  "name": "image-checker",
  "version": "1.0.0",
  "description": "GitHub Action to analyze and validate images added to Plone repositories.",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.js -o dist --source-map --license licenses.txt",
    "test": "jest --coverage",
    "lint": "eslint src/ __tests__/",
    "lint:fix": "eslint src/ __tests__/ --fix",
    "dry-release": "release-it --dry-run --no-hooks",
    "release": "release-it",
    "release-major-alpha": "release-it major --preRelease=alpha",
    "release-alpha": "release-it --preRelease=alpha"
  },
  "keywords": [
    "github-action",
    "image",
    "validation"
  ],
  "homepage": "https://github.com/kitconcept/image-checker#readme",
  "repository": {
    "type": "git",
    "url": "git@github.com:kitconcept/image-checker.git"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "image-size": "^2.0.2"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "release-it": "^19.0.5"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
